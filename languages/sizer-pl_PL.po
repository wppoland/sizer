#~ msgid "Trigger label"
#~ msgstr "Etykieta przycisku"

#~ msgid "Modal title"
#~ msgstr "Tytuł okna modalnego"

#~ msgid "The text shown on the button."
#~ msgstr "Tekst wyświetlany na przycisku."

#~ msgid ""
#~ "Heading shown at the top of the modal. Defaults to the trigger label."
#~ msgstr ""
#~ "Nagłówek wyświetlany u góry okna modalnego. Domyślnie zgodny z etykietą "
#~ "przycisku."
